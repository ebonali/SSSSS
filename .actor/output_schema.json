      "description": "The base URL of the targeted website."
    },
    "emails": {
      "title": "Email Addresses",
      "type": "array",
      "items": { "type": "string" },
      "description": "A list of email addresses found on the site."
    },
    "phones": {
      "title": "Phone Numbers",
      "type": "array",
      "items": { "type": "string" },
      "description": "A list of phone numbers (formatted where possible)."
    },
    "linkedin": {
      "title": "LinkedIn Profiles",
      "type": "array",
      "items": { "type": "string" },
      "description": "Discovered LinkedIn company or personal profiles."
    },
    "facebook": {
      "title": "Facebook Profiles",
      "type": "array",
      "items": { "type": "string" },
      "description": "Discovered Facebook pages."
    },
    "twitter": {
      "title": "Twitter (X) Profiles",
      "type": "array",
      "items": { "type": "string" },
      "description": "Discovered Twitter accounts."
    },
    "instagram": {
      "title": "Instagram Profiles",
      "type": "array",
      "items": { "type": "string" },
      "description": "Discovered Instagram accounts."
    },
    "youtube": {
      "title": "YouTube Channels",
      "type": "array",
      "items": { "type": "string" }
    },
    "tiktok": {
      "title": "TikTok Profiles",
      "type": "array",
      "items": { "type": "string" }
    },
    "whatsapp": {
